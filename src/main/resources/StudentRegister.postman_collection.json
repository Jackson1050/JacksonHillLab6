  "item": [
    {
      "name": "Add Student",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "var jsonData = pm.response.json();\r",
              "\r",
              "pm.test(\"Response structure is correct\", () => {\r",
              "    pm.expect(jsonData).to.have.all.keys('id', 'name', 'major', 'gpa');\r",
              "});\r",
              "\r",
              "pm.test(\"Fields have correct types\", () => {\r",
              "    pm.expect(jsonData.name).to.be.a('string');\r",
              "    pm.expect(jsonData.major).to.be.a('string');\r",
              "    pm.expect(jsonData.gpa).to.be.a('number');\r",
              "});\r",
              "\r",
              "pm.test(\"Check specific values\", () => {\r",
              "    pm.expect(jsonData.gpa).to.be.at.most(4.0);\r",
              "    pm.expect(jsonData.gpa).to.be.at.least(0.0);\r",
              "});\r",
              "\r",
              "pm.test(\"Test string size\", () => {\r",
              "    pm.expect(jsonData.name.length).to.be.at.most(255);\r",
              "    pm.expect(jsonData.name.length).to.be.at.least(1);\r",
              "});\r",
              "\r",
              "//Ensure the student count does not exceed classSize\r",
              "let newStudent = pm.request.body.raw ? JSON.parse(pm.request.body.raw) : {};\r",
              "let major = newStudent.major;\r",
              "\r",
              "pm.sendRequest({\r",
              "    url: \"http://localhost:8080/api/students\",\r",
              "    method: \"GET\"\r",
              "}, function(err, res) {\r",
              "    let students = res.json();\r",
              "    let count = students.filter(student => student.major === major).length;\r",
              "\r",
              "    pm.sendRequest({\r",
              "        url: \"http://localhost:8080/api/courses\",\r",
              "        method: \"GET\"\r",
              "    }, function(err, res) {\r",
              "        let courses = res.json();\r",
              "        let course = courses.find(c => c.name === major);\r",
              "\r",
              "        pm.test(\"Class size not exceeded\", () => {\r",
              "            pm.expect(count + 1).to.be.at.most(course.classSize);\r",
              "        });\r",
              "    });\r",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        },
        {
          "listen": "prerequest",
          "script": {
            "exec": [
              ""
